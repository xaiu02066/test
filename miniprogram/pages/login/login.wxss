/* pages/login/login.wxss */
.page {
  min-height: 100vh;
  padding: 60rpx 48rpx 80rpx;
  background:
    radial-gradient(600rpx 400rpx at 80% 0%, rgba(232, 125, 59, 0.10), transparent 60%),
    var(--bg);
}

/* 品牌区 */
.brand { text-align: center; margin-bottom: 56rpx; }
.brand-mark {
  width: 96rpx; height: 96rpx; border-radius: 26rpx;
  background: linear-gradient(145deg, #FFB877, #E87D3B);
  color: #fff; font-weight: 800; font-size: 52rpx;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 20rpx;
  box-shadow: 0 16rpx 36rpx -10rpx rgba(232, 125, 59, 0.55);
}
.brand-name { font-size: 44rpx; font-weight: 800; color: var(--text); }
.brand-desc { font-size: 24rpx; color: var(--text-mute); margin-top: 8rpx; }

/* Tabs */
.tabs {
  display: flex; gap: 12rpx; margin-bottom: 28rpx;
  background: var(--bg-soft); padding: 8rpx; border-radius: 18rpx;
}
.tab {
  flex: 1; text-align: center; padding: 20rpx 0;
  font-size: 28rpx; color: var(--text-mute); border-radius: 12rpx;
  transition: all .2s;
}
.tab.active { background: var(--accent); color: #fff; font-weight: 600; }

/* 表单卡片 */
.form { padding: 40rpx 32rpx; }
.field { margin-bottom: 28rpx; }
.label { display: block; font-size: 26rpx; color: var(--text-mute); margin-bottom: 14rpx; }
.ph { color: var(--text-dim); }

.hint {
  text-align: center; font-size: 24rpx; color: var(--text-dim);
  margin-top: 24rpx; font-family: var(--font-mono, monospace);
}
