<!-- pages/home/home.wxml —— 个人主页 -->
<view class="page">

  <!-- 头部名片 -->
  <view class="hero">
    <view class="avatar lg">{{user.username[0]}}</view>
    <view class="hero-name">{{user.username}}</view>
    <view class="hero-email">{{user.email}}</view>
    <view class="hero-badges">
      <text class="badge {{user.role}}">{{user.role === 'admin' ? '管理员' : '普通用户'}}</text>
      <text class="badge {{user.status === 1 ? 'on' : 'off'}}">{{user.status === 1 ? '启用' : '禁用'}}</text>
    </view>
  </view>

  <!-- 信息卡 -->
  <view class="card info-card">
    <view class="info-row">
      <text class="info-key">用户 ID</text>
      <text class="info-val">{{user.id}}</text>
    </view>
    <view class="info-row">
      <text class="info-key">用户名</text>
      <text class="info-val">{{user.username}}</text>
    </view>
    <view class="info-row">
      <text class="info-key">邮箱</text>
      <text class="info-val">{{user.email}}</text>
    </view>
    <view class="info-row">
      <text class="info-key">角色</text>
      <text class="info-val">{{user.role === 'admin' ? '管理员' : '普通用户'}}</text>
    </view>
    <view class="info-row">
      <text class="info-key">状态</text>
      <text class="info-val {{user.status === 1 ? 'green' : 'red'}}">{{user.status === 1 ? '启用' : '禁用'}}</text>
    </view>
    <view class="info-row">
      <text class="info-key">注册时间</text>
      <text class="info-val">{{user.created_at}}</text>
    </view>
  </view>

  <!-- 操作 -->
  <view class="actions">
    <button class="btn-primary" wx:if="{{user.role === 'admin'}}" bindtap="goAdmin">进入管理后台</button>
    <button class="btn-ghost" bindtap="logout">退出登录</button>
  </view>

</view>
