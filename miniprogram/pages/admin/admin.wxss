/* pages/admin/admin.wxss */
.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 60rpx;
  background:
    radial-gradient(500rpx 360rpx at 90% 0%, rgba(232, 125, 59, 0.10), transparent 60%),
    var(--bg);
}

/* 顶部栏 */
.topbar {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 32rpx;
}
.brand { display: flex; align-items: center; gap: 18rpx; }
.brand-mark {
  width: 72rpx; height: 72rpx; border-radius: 20rpx;
  background: linear-gradient(145deg, #FFB877, #E87D3B);
  color: #fff; font-weight: 800; font-size: 36rpx;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 12rpx 28rpx -8rpx rgba(232, 125, 59, 0.5);
}
.brand-name { font-size: 34rpx; font-weight: 800; color: var(--text); }
.brand-sub { font-size: 22rpx; color: var(--text-mute); margin-top: 4rpx; }
.logout {
  font-size: 26rpx; color: var(--red);
  padding: 12rpx 24rpx; border: 1px solid rgba(220, 96, 74, 0.3);
  border-radius: 12rpx; background: var(--red-soft);
}

/* 统计 */
.stats { display: flex; gap: 16rpx; margin-bottom: 28rpx; }
.stat { flex: 1; padding: 24rpx 12rpx; text-align: center; }
.stat-num { font-size: 44rpx; font-weight: 800; color: var(--text); }
.stat-num.green { color: var(--green); }
.stat-num.red { color: var(--red); }
.stat-num.accent { color: var(--accent); }
.stat-label { font-size: 22rpx; color: var(--text-mute); margin-top: 6rpx; }

/* 工具栏 */
.toolbar { padding: 24rpx; margin-bottom: 28rpx; }
.search-row { display: flex; gap: 16rpx; margin-bottom: 18rpx; }
.search-input {
  flex: 1; height: 76rpx; background: var(--bg);
  border: 1px solid var(--border); border-radius: 12rpx;
  padding: 0 24rpx; font-size: 26rpx;
}
.search-btn {
  background: var(--accent); color: #fff;
  padding: 0 32rpx; height: 76rpx; line-height: 76rpx;
  border-radius: 12rpx; font-size: 26rpx; font-weight: 600;
}
.filter-row { display: flex; gap: 16rpx; flex-wrap: wrap; align-items: center; }
.picker { background: var(--bg); border: 1px solid var(--border); border-radius: 12rpx; }
.picker-inner { height: 64rpx; line-height: 64rpx; padding: 0 22rpx; font-size: 24rpx; color: var(--text-mute); }
.add-btn {
  margin-left: auto; background: var(--accent-soft); color: var(--accent);
  padding: 0 28rpx; height: 64rpx; line-height: 64rpx;
  border-radius: 12rpx; font-size: 26rpx; font-weight: 600;
  border: 1px solid var(--accent-line);
}

/* 列表 */
.list-title { font-size: 26rpx; color: var(--text-mute); margin: 0 4rpx 16rpx; }
.empty { text-align: center; padding: 80rpx 0; color: var(--text-dim); }
.empty-ic { font-size: 64rpx; margin-bottom: 16rpx; }

.user {
  display: flex; align-items: center; gap: 20rpx;
  padding: 24rpx; margin-bottom: 18rpx;
}
.info { flex: 1; min-width: 0; }
.line1 { display: flex; align-items: center; gap: 10rpx; }
.uname { font-size: 30rpx; font-weight: 700; color: var(--text); }
.line2 {
  font-size: 24rpx; color: var(--text-mute); margin-top: 8rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.actions { display: flex; flex-direction: column; gap: 10rpx; }
.act {
  font-size: 22rpx; padding: 8rpx 18rpx; border-radius: 10rpx;
  text-align: center; min-width: 80rpx;
}
.act.toggle { background: var(--bg-soft); color: var(--text-mute); }
.act.edit { background: var(--accent-soft); color: var(--accent); }
.act.del { background: var(--red-soft); color: var(--red); }

/* 分页 */
.pager {
  display: flex; align-items: center; justify-content: center; gap: 28rpx;
  margin-top: 24rpx;
}
.page-btn {
  padding: 16rpx 36rpx; background: var(--bg-elev);
  border: 1px solid var(--border); border-radius: 12rpx;
  font-size: 26rpx; color: var(--text);
}
.page-btn.dis { opacity: 0.4; }
.page-info { font-size: 26rpx; color: var(--text-mute); }

.bottom-space { height: 60rpx; }

/* 弹窗 */
.modal-mask {
  position: fixed; inset: 0; z-index: 50;
  background: rgba(90, 50, 20, 0.45);
  display: flex; align-items: center; justify-content: center;
  padding: 48rpx;
}
.modal { width: 100%; max-width: 640rpx; padding: 36rpx 32rpx; }
.modal-title { font-size: 34rpx; font-weight: 800; margin-bottom: 28rpx; text-align: center; }
.m-field { margin-bottom: 22rpx; }
.m-label { display: block; font-size: 24rpx; color: var(--text-mute); margin-bottom: 10rpx; }
.modal-btns { display: flex; gap: 18rpx; margin-top: 16rpx; }
.modal-btns button { flex: 1; }

.ph { color: var(--text-dim); }
